// Ferro plugin ABI (v0.1, locked).
//
// Plugins implement the `guest` interface; the host implements `host`.
// Build plugins with `wit-bindgen rust` (or another toolchain) targeting
// this world, then package the component with `wasm-tools component new`.

package ferro:cms@0.1.0;

interface types {
    type content-id = string;
    type site-id = string;

    record content {
        id: content-id,
        site-id: site-id,
        type-slug: string,
        slug: string,
        locale: string,
        status: string,
        data-json: string,
    }

    record content-deleted {
        content-id: content-id,
        slug: string,
    }

    enum log-level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    variant hook-event {
        content-created(content),
        content-updated(content),
        content-published(content),
        content-deleted(content-deleted),
    }
}

// Host → Plugin imports. Each call is capability-checked at the host before
// servicing; a missing grant returns an `err`.
interface host {
    use types.{content, content-id, log-level};

    /// Emit a structured log line. Requires `logs` capability.
    log: func(level: log-level, target: string, message: string);

    /// Fetch a content row by id. Returns `none` when missing or unauthorized.
    /// Requires `content.read` capability.
    get-content: func(id: content-id) -> option<content>;
}

// Plugin → Host exports. The plugin implements both functions; `init` runs
// once at load time, `on-event` runs for each hook firing the manifest
// subscribed to.
interface guest {
    use types.{hook-event};

    init: func() -> result<_, string>;
    on-event: func(evt: hook-event) -> result<_, string>;
}

world plugin {
    import host;
    export guest;
}
