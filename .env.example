# Ferro configuration (example)
# Copy to .env and edit.

# --- server ---
FERRO_BIND=0.0.0.0:8080
FERRO_PUBLIC_URL=http://localhost:8080
RUST_LOG=info,ferro=debug

# --- storage ---
# One of: surreal-embedded | surreal-remote | postgres | fs-json | fs-markdown
FERRO_STORAGE=surreal-embedded
FERRO_STORAGE_PATH=./data/ferro.db
# FERRO_STORAGE_URL=postgres://user:pass@localhost/ferro
# FERRO_STORAGE_URL=ws://localhost:8000

# --- auth ---
FERRO_SESSION_SECRET=change-me-32-bytes-min-please-do-not-ship-this-value
FERRO_JWT_ISSUER=ferro
# FERRO_JWT_PRIVATE_KEY_PATH=./keys/jwt.pem

# --- media ---
# One of: local | s3 | gcs
FERRO_MEDIA=local
FERRO_MEDIA_PATH=./media-store
# FERRO_MEDIA_BUCKET=ferro-media
# FERRO_MEDIA_REGION=us-east-1

# --- plugins ---
FERRO_PLUGIN_DIR=./plugins
FERRO_PLUGIN_MAX_MEM_MB=128
FERRO_PLUGIN_FUEL_PER_REQUEST=10000000
